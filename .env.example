# ----------------------------------------------------------------------
# South Sound Theatre Artists - environment variables
# ----------------------------------------------------------------------
# Copy this file to .env and fill in values from the password manager.
# Never commit .env to git.

# ----------------------------------------------------------------------
# Supabase
# ----------------------------------------------------------------------
# Found in Supabase dashboard: Project Settings > API
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-public-jwt-here

# Server-only - bypasses RLS, never expose to browser code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-jwt-here

# Postgres connection string for running migrations (Session pooler URI from
# Supabase dashboard: Connect button > Session pooler tab > port 5432).
# Server-only, used by scripts/migrate.mjs - never imported by app code.
SUPABASE_DB_URL=postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# ----------------------------------------------------------------------
# Cloudinary
# ----------------------------------------------------------------------
# Found in Cloudinary dashboard. Cloud name is public; secret is server-only.
PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-numeric-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ----------------------------------------------------------------------
# Resend
# ----------------------------------------------------------------------
# Created in Resend dashboard: API Keys
RESEND_API_KEY=re_your_api_key_here

# Default "from" address (must be verified domain or use onboarding@resend.dev for dev)
RESEND_FROM_EMAIL=noreply@southsoundtheatreartists.com
RESEND_REPLY_TO_EMAIL=lexi@southsoundtheatreartists.com

# ----------------------------------------------------------------------
# Admin Authentication
# ----------------------------------------------------------------------
# The single admin password (Lexi's). Picked once, can be rotated via env var update.
ADMIN_PASSWORD=pick-a-strong-password-here

# Where 2FA codes and admin notifications get sent. Use Lexi's domain email.
ADMIN_EMAIL=lexi@southsoundtheatreartists.com

# Used to sign session cookies. Generate with: openssl rand -base64 32
SESSION_SECRET=generate-a-random-32-byte-string-here

# ----------------------------------------------------------------------
# Site Configuration
# ----------------------------------------------------------------------
# Public origin used for absolute URLs in emails (magic links, etc.)
# Local dev: http://localhost:5173
# Netlify preview: https://southsoundtheatreartists.netlify.app
# Production (post-launch with custom domain): https://southsoundtheatreartists.com
PUBLIC_SITE_URL=http://localhost:5173

# Set to 'production' on Netlify, 'development' locally
NODE_ENV=development

# ----------------------------------------------------------------------
# Analytics (GoatCounter - free for non-commercial, no cookies, no GDPR
# banner needed). Sign up at https://www.goatcounter.com to claim a
# subdomain. Leave blank to disable analytics in dev.
#
# Example: if your dashboard is https://southsoundtheatre.goatcounter.com,
# the value here is `southsoundtheatre`.
# ----------------------------------------------------------------------
PUBLIC_GOATCOUNTER_CODE=
