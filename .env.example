# ----------------------------------------------------------------------
# South Sound Theatre Artists - environment variables
# ----------------------------------------------------------------------
# Copy this file to .env and fill in values from the password manager.
# Never commit .env to git.

# ----------------------------------------------------------------------
# Supabase
# ----------------------------------------------------------------------
# Found in Supabase dashboard: Project Settings > API
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-public-jwt-here

# Server-only - bypasses RLS, never expose to browser code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-jwt-here

# Postgres connection string for running migrations (Session pooler URI from
# Supabase dashboard: Connect button > Session pooler tab > port 5432).
# Server-only, used by scripts/migrate.mjs - never imported by app code.
SUPABASE_DB_URL=postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# ----------------------------------------------------------------------
# Cloudinary
# ----------------------------------------------------------------------
# Found in Cloudinary dashboard. Cloud name is public; secret is server-only.
PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-numeric-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ----------------------------------------------------------------------
# Resend
# ----------------------------------------------------------------------
# Created in Resend dashboard: API Keys
RESEND_API_KEY=re_your_api_key_here

# Default "from" address (must be verified domain or use onboarding@resend.dev for dev).
# Use the "Display Name <email>" format so mail clients show the org name as the
# sender instead of falling back to the local-part of the email address (e.g.
# "hello" when the address is hello@southsoundtheatreartists.org).
RESEND_FROM_EMAIL=South Sound Theatre Artists <noreply@southsoundtheatreartists.org>
RESEND_REPLY_TO_EMAIL=lexi@southsoundtheatreartists.org

# Pre-launch kill switch. When set to "true", every email_templates row
# tagged audience='community' (artist welcomes, magic links, weekly digest,
# callboard verifies, etc.) is intercepted before Resend is hit and logged
# to email_log with status='paused'. audience='admin' templates (2FA codes,
# daily digest, volume alert) keep flowing so Lexi can still log in.
# Flip to false / unset when ready to mail real artists.
EMAIL_PAUSE_COMMUNITY=true

# Comma-separated list of recipient emails that bypass the pause above.
# Lets specific addresses (Lexi, Blake) test community-audience flows on
# staging while every other recipient stays safe. Recipient is matched
# case-insensitive on the trimmed lowercase email. Leave blank to pause
# every community-audience send unconditionally.
EMAIL_PAUSE_ALLOWLIST=mslexibarnett@gmail.com,blake@blakeryork.com

# ----------------------------------------------------------------------
# Admin Authentication
# ----------------------------------------------------------------------
# The single admin password (Lexi's). Picked once, can be rotated via env var update.
ADMIN_PASSWORD=pick-a-strong-password-here

# Where 2FA codes and admin notifications get sent. Use Lexi's domain email.
ADMIN_EMAIL=lexi@southsoundtheatreartists.org

# ----------------------------------------------------------------------
# Site Configuration
# ----------------------------------------------------------------------
# Public origin used for absolute URLs in emails (magic links, etc.)
# Local dev: http://localhost:5173
# Netlify preview: https://southsoundtheatreartists.netlify.app
# Production (post-launch with custom domain): https://southsoundtheatreartists.org
PUBLIC_SITE_URL=http://localhost:5173

# Set to 'production' on Netlify, 'development' locally
NODE_ENV=development

# ----------------------------------------------------------------------
# Analytics (GoatCounter - free for non-commercial, no cookies, no GDPR
# banner needed). Sign up at https://www.goatcounter.com to claim a
# subdomain. Leave blank to disable analytics in dev.
#
# Example: if your dashboard is https://southsoundtheatre.goatcounter.com,
# the value here is `southsoundtheatre`.
# ----------------------------------------------------------------------
PUBLIC_GOATCOUNTER_CODE=

# ----------------------------------------------------------------------
# Ko-fi donation widget. The username is the URL slug after ko-fi.com/
# (e.g. for ko-fi.com/lexibarnettssta the value is `lexibarnettssta`).
# Drives the embedded donation widget on /support-us. Leave blank to
# hide the widget entirely.
# ----------------------------------------------------------------------
PUBLIC_KOFI_USERNAME=

# ----------------------------------------------------------------------
# Dev-only: skip the admin 2FA email step on /admin/login. Only honored
# when `pnpm dev` (vite dev mode); production builds hardcode the check
# to false. Useful for iterating on admin pages without burning email
# codes. Leave unset on staging/production.
# ----------------------------------------------------------------------
ADMIN_SKIP_2FA=

# ----------------------------------------------------------------------
# Anthropic API (v2.x calendar feature)
# ----------------------------------------------------------------------
# Used by the auto-populated calendar's AI extraction adapter to pull
# upcoming productions from theatre season pages. Get a key at
# https://console.anthropic.com/settings/keys (new accounts ship with
# $5 in free credits, which covers ~5 years at our projected volume).
#
# Set a hard monthly spend cap in console.anthropic.com -> Plans &
# Billing -> Usage limits as belt-and-suspenders against runaway calls.
#
# Leave blank to disable calendar auto-population in dev.
# ----------------------------------------------------------------------
ANTHROPIC_API_KEY=
